# ============================================================
#  gem-trader  —  credential & runtime configuration
#  Copy to .env and fill in real values. Never commit .env.
# ============================================================

# ── Alpaca Pro Plus ─────────────────────────────────────────
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_BASE_URL=https://api.alpaca.markets
ALPACA_DATA_URL=https://data.alpaca.markets
ALPACA_PAPER=true                                    # true = paper trading

# ── Financial Modeling Prep (Starter Annual) ─────────────────
FMP_API_KEY=
FMP_BASE_URL=https://financialmodelingprep.com/api
FMP_CALLS_PER_MINUTE=300                             # Starter Annual plan
FMP_DAILY_BUDGET=3000                                # conservative daily cap

# ── SQLite + cache paths ─────────────────────────────────────
DB_PATH=/home/gem/trading-production/db/trading.db
CACHE_DIR=/home/gem/trading-production/cache
LOG_DIR=/home/gem/trading-production/logs
LOG_LEVEL=INFO

# ── Risk limits ──────────────────────────────────────────────
MAX_POSITION_PCT=0.02          # 2 % of equity per trade
MAX_DAILY_LOSS_PCT=0.05        # 5 % hard circuit-breaker
ALLOW_SHORTS=true
PAPER_TRADING=true
ALLOW_LIVE_CAPITAL=false
LIVE_CONFIRM_FILE=

# ── Regime freshness SLA ─────────────────────────────────
REGIME_FRESHNESS_MAX_MINUTES=1440
REGIME_STALE_BEHAVIOR_PAPER=warn
REGIME_STALE_BEHAVIOR_LIVE=block
